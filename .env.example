# Variabili d'ambiente
# Copia questo file in .env e compila i valori reali
# NON committare mai .env — è in .gitignore

# === Google OAuth ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# === Google Sheets / Drive ===
# SPREADSHEET_ID=

# === API Esterne ===
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# === Database (se necessario) ===
# DATABASE_URL=

# === App Config ===
# ENVIRONMENT=development  # development | production
# DEBUG=true
